# =====================================================
# 환경 변수 예시. 실제 값은 .env.local (개발) / Vercel 환경 변수에 설정.
# 운영 가이드: docs/07-technical.md, docs/09-monitoring.md
# =====================================================

# ─── Storage / KV (Vercel KV / Upstash 호환) ───
# 없으면 코옵·대련·채팅·피드백·메트릭스 비활성 (graceful fallback)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── AI 보고서 (Anthropic) ───
# 없으면 mockReport 텍스트로 대체
ANTHROPIC_API_KEY=

# ─── 관리자 ───
# /admin?key=... 인증 + 피드백/EXP grant 등 보호 API
ADMIN_KEY=

# ─── 테스트 모드 ───
# "1" 또는 dev 환경: BOSS_COOLDOWN_MS=1분, TEST_REWARD_MULT=50
# 운영(prod) + 미설정: BOSS_COOLDOWN_MS=30분, TEST_REWARD_MULT=1
NEXT_PUBLIC_TEST_MODE=

# ─── 사용자 피드백 폼 ───
# "1"이면 우하단 floating 💬 버튼 노출
NEXT_PUBLIC_FEEDBACK_ENABLED=1

# IP 해시 솔트 (피드백 익명 ID 생성). 운영 환경에서 강한 무작위 값으로 설정.
IP_SALT=change-me-to-random-string

# ─── Sentry (에러 모니터링) ───
# 미설정 시 Sentry SDK는 noop
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# source map 업로드 시에만 필요
SENTRY_AUTH_TOKEN=

# ─── Slack 알림 (Phase 4 — 선택) ───
SLACK_WEBHOOK_URL=
