# Vercel Marketplace 통합이 자동 주입하는 변수들. 로컬 개발 시:
#   $ vercel env pull .env.development.local
# 으로 실제 값을 받아온다. 이 파일은 어떤 변수가 필요한지 보여주는 참조용.

# Auth.js (NextAuth) — https://authjs.dev/getting-started/installation
# 32자 이상 랜덤 문자열. `openssl rand -base64 32` 로 생성.
AUTH_SECRET=your_auth_secret_here

# Google OAuth — Google Cloud Console에서 발급.
# Callback URL: {domain}/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# Kakao OAuth — https://developers.kakao.com 에서 발급.
# Callback URL: {domain}/api/auth/callback/kakao
AUTH_KAKAO_ID=your_kakao_rest_api_key
AUTH_KAKAO_SECRET=your_kakao_client_secret

# Neon Postgres (Vercel Marketplace → Neon → Install)
DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# /admin 페이지 접근 허용 이메일 (콤마 구분, OAuth 계정의 이메일과 매칭).
# 비어있으면 모든 사용자가 차단된다 (404).
ADMIN_EMAILS=you@example.com
