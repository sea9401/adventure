{
  "name": "adventure-rpg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run optimize-images && npm run check-images",
    "dev": "next dev",
    "prebuild": "npm run optimize-images && npm run check-images && npm run db:migrate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "optimize-images": "node scripts/optimize-images.mjs",
    "check-images": "node scripts/check-images.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.mjs",
    "db:baseline-mark": "node src/db/baseline-mark.mjs"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@phosphor-icons/react": "^2.1.10",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.5",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}
